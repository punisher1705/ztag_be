.PHONY: help up down restart build logs ps shell db-shell redis-cli \
        migrate migrate-create migrate-downgrade \
        test test-unit test-integration test-cov \
        lint format typecheck \
        seed clean prune ollama-pull

# ============================================================
# Zero-Trust API Gateway — Developer Makefile
# Run `make help` to see all available commands.
# ============================================================

COMPOSE        := docker-compose
APP_SERVICE    := gateway
DB_SERVICE     := mysql
REDIS_SERVICE  := redis
OLLAMA_SERVICE := ollama
PYTEST         := $(COMPOSE) exec $(APP_SERVICE) pytest
PYTHON         := $(COMPOSE) exec $(APP_SERVICE) python

help: ## Show this help message
	@echo "Available targets:"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

# --- Environment setup ---

env: ## Copy .env.example to .env if .env doesn't already exist
	@test -f .env || cp .env.example .env
	@echo ".env is ready — edit it before first run if needed."

sync: ## Install/sync all Python deps locally via uv (for running things outside Docker)
	uv sync

check-config: sync ## Quick local sanity check that .env loads correctly, no Docker needed
	uv run python scripts/check_config.py

# --- Lifecycle ---

up: env ## Start all services in the background
	$(COMPOSE) up -d --build
	@echo "Gateway:     http://localhost:5001"
	@echo "Swagger UI:  http://localhost:5001/docs"
	@echo "Grafana:     http://localhost:3000"
	@echo "Prometheus:  http://localhost:9090"

down: ## Stop and remove all containers
	$(COMPOSE) down

restart: down up ## Restart the full stack

build: ## Rebuild all images without starting containers
	$(COMPOSE) build

logs: ## Tail logs from all services
	$(COMPOSE) logs -f

logs-app: ## Tail logs from the gateway service only
	$(COMPOSE) logs -f $(APP_SERVICE)

ps: ## List running containers for this project
	$(COMPOSE) ps

# --- Shells ---

shell: ## Open a bash shell inside the gateway container
	$(COMPOSE) exec $(APP_SERVICE) bash

db-shell: ## Open a MySQL shell inside the db container
	$(COMPOSE) exec $(DB_SERVICE) mysql -u$${DB_USER:-gateway_user} -p$${DB_PASSWORD} $${DB_NAME:-gateway_db}

redis-cli: ## Open a redis-cli session inside the redis container
	$(COMPOSE) exec $(REDIS_SERVICE) redis-cli

# --- Database migrations (Alembic) ---

migrate: ## Apply all pending migrations
	$(COMPOSE) exec $(APP_SERVICE) alembic upgrade head

migrate-create: ## Generate a new migration — usage: make migrate-create msg="add users table"
	$(COMPOSE) exec $(APP_SERVICE) alembic revision --autogenerate -m "$(msg)"

migrate-downgrade: ## Roll back the last migration
	$(COMPOSE) exec $(APP_SERVICE) alembic downgrade -1

migrate-history: ## Show migration history
	$(COMPOSE) exec $(APP_SERVICE) alembic history --verbose

# --- Testing ---

test: ## Run the full test suite
	$(PYTEST) -v

test-unit: ## Run unit tests only
	$(PYTEST) tests/unit -v

test-integration: ## Run integration tests only
	$(PYTEST) tests/integration -v

test-cov: ## Run tests with coverage report
	$(PYTEST) --cov=app --cov-report=term-missing --cov-report=html

# --- Code quality ---

lint: ## Run ruff lint checks
	$(COMPOSE) exec $(APP_SERVICE) ruff check app tests

format: ## Auto-format code with ruff
	$(COMPOSE) exec $(APP_SERVICE) ruff format app tests

typecheck: ## Run mypy static type checking
	$(COMPOSE) exec $(APP_SERVICE) mypy app

# --- Data / model setup ---

seed: ## Seed the database with sample data (admin user, sample api keys)
	$(PYTHON) -m app.scripts.seed

ollama-pull: ## Pull the configured local LLM model into the Ollama container
	$(COMPOSE) exec $(OLLAMA_SERVICE) ollama pull llama3.1:8b

# --- Cleanup ---

clean: ## Stop containers and remove volumes (WARNING: deletes local db/redis data)
	$(COMPOSE) down -v

prune: ## Remove dangling Docker images/build cache
	docker system prune -f

# --- Versioning ---

version: ## Print the current app version
	@uv run python -c "from app.core.version import __version__; print(__version__)"

bump-patch: ## Bump PATCH version (0.1.0 -> 0.1.1), commit, and tag
	uv run bump-my-version bump patch

bump-minor: ## Bump MINOR version (0.1.0 -> 0.2.0), commit, and tag
	uv run bump-my-version bump minor

bump-major: ## Bump MAJOR version (0.1.0 -> 1.0.0), commit, and tag
	uv run bump-my-version bump major

release: ## Push the current branch and tags — triggers the release pipeline
	git push && git push --tags