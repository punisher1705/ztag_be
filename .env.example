# ============================================================
# Zero-Trust API Gateway — Environment Configuration Template
# Copy this file to .env and fill in real values for local dev.
# NEVER commit the actual .env file.
# ============================================================

# --- App ---
APP_ENV=development                 # development | staging | production
APP_NAME=zero-trust-gateway
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-64-char-string
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
HOST=0.0.0.0
PORT=5000

# --- Database (MySQL) ---
DB_HOST=mysql
DB_PORT=3306
DB_ROOT_PASSWORD=rootpassword
DB_NAME=gateway_db
DB_USER=gateway_user
DB_PASSWORD=userpassword
# Full URL is assembled by app/core/config.py from the above,
# but can be overridden directly if needed:
# DATABASE_URL=mysql+pymysql://gateway_user:change-me@mysql:3306/gateway_db

# --- Redis (rate limiting + token blacklist store) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redispassword

# --- JWT / Auth ---
JWT_SECRET_KEY=change-me-to-a-different-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
JWT_ISSUER=zero-trust-gateway

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute        # applied per API key / IP if no key
RATE_LIMIT_STORAGE_URL=redis://redis:6379/1

# --- Anomaly Detection (LLM-assisted) ---
# Local open-weight model served via Ollama. No API key needed for local dev.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
ANOMALY_CHECK_ENABLED=true
ANOMALY_CHECK_WINDOW_MINUTES=5
# Optional hosted fallback for open-weight models (still open-weight, hosted inference).
# Leave blank to stay fully local.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=zero-trust-gateway
PROMETHEUS_METRICS_PATH=/metrics

# --- Downstream service registry (what the gateway proxies to) ---
# Comma-separated service_name:base_url pairs, parsed at startup.
DOWNSTREAM_SERVICES=inventory:http://inventory-service:8000,orders:http://orders-service:8001
